# Copy to .env for local development. In production these come from the
# compose stack's environment on the VPS (see docker-compose.yml).
ARANGO_URL=http://127.0.0.1:8529
ARANGO_DB=leksis
ARANGO_USER=root
ARANGO_PASSWORD=
# CORS is handled by Caddy in production (see Caddyfile). For local dev the API
# emits no CORS headers; run the web app against a local API or tunnel.
PORT=8080
# Jetstream endpoint the firehose consumer subscribes to (ADR-0003).
# Default: wss://jetstream2.us-east.bsky.network/subscribe
#JETSTREAM_URL=
