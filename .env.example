# Copy to .env on the server (and locally) for docker-compose.
# .env is gitignored — never commit real secrets.

# ArangoDB root password (used by the arangodb container and the API).
ARANGO_ROOT_PASSWORD=change-me

# Project database name.
ARANGO_DB=leksis

# Caddy site address. ":80" = HTTP only. Set to "leksis.eu" once DNS points
# here to enable automatic HTTPS.
SITE_ADDRESS=:80

# CORS for the API is handled entirely by Caddy (see Caddyfile). Same-origin
# leksis.eu traffic needs none; cross-origin dev access is granted per source IP
# via ALLOWED_IPS below.

# --- Aardvark: ArangoDB admin UI at aardvark.leksis.eu (optional) ---
# Leave both unset to keep Aardvark unreachable — the docker-compose defaults
# fail closed. Access is gated by the IP allowlist below PLUS ArangoDB's own
# root login on the Aardvark page (user "root", password = ARANGO_ROOT_PASSWORD
# above). To expose it, add a DNS A/AAAA record for aardvark.leksis.eu pointing
# at this server, then set:
#
# 1. Hostname — presence of a real domain makes Caddy provision HTTPS.
# AARDVARK_ADDRESS=aardvark.leksis.eu
#
# 2. Allowed source IPs/CIDRs, space-separated. Everyone else gets 403.
#    Default is localhost-only (nobody). Example: one fixed office/home IP.
#
#    This allowlist ALSO governs cross-origin API access (see Caddyfile): a
#    developer running the web app locally (e.g. http://localhost:5173) can call
#    the production /api/* only from an IP listed here — the browser blocks all
#    other cross-origin callers with a CORS error. Same-origin leksis.eu users
#    are unaffected from any IP.
# ALLOWED_IPS=203.0.113.7/32

# --- Bot PDS: AT Proto personal data server at pds.leksis.eu ---
# Hosts the accounts of the scraper bots (and nothing else). The three secrets
# below are REQUIRED — docker compose refuses to start without them (generate
# once, then never change PDS_PLC_ROTATION_KEY: it anchors the bots' DIDs).
#
#   PDS_JWT_SECRET:       openssl rand --hex 16
#   PDS_ADMIN_PASSWORD:   openssl rand --hex 16
#   PDS_PLC_ROTATION_KEY: openssl ecparam --name secp256k1 --genkey --noout --outform DER | tail --bytes=+8 | head --bytes=32 | xxd --plain --cols 32
PDS_JWT_SECRET=change-me
PDS_ADMIN_PASSWORD=change-me
PDS_PLC_ROTATION_KEY=change-me

# The PDS stays unreachable (internal Caddy listeners) until both addresses are
# set. The *.leksis.eu DNS wildcard must point at this server (it does). Bot
# handles live directly under leksis.eu, e.g. wikbot.leksis.eu.
# PDS_ADDRESS=pds.leksis.eu
# PDS_HANDLES_ADDRESS=*.leksis.eu
#
# Account/session creation, all writes, app passwords, etc. are only reachable
# from ALLOWED_IPS above (deny-by-default at the Caddy edge). The public surface
# is limited to what federation and reads need — /.well-known/*, com.atproto
# sync.*/identity.*/server.describeServer, and repo.getRecord/listRecords/
# describeRepo — because the Bluesky relay crawls the PDS (that is how bot
# records reach Jetstream and the AppView) and anyone may read a bot's records.
