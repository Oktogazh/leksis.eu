# Copy to .env on the server (and locally) for docker-compose.
# .env is gitignored — never commit real secrets.

# ArangoDB root password (used by the arangodb container and the API).
ARANGO_ROOT_PASSWORD=change-me

# Project database name.
ARANGO_DB=leksis

# Caddy site address. ":80" = HTTP only. Set to "leksis.eu" once DNS points
# here to enable automatic HTTPS.
SITE_ADDRESS=:80

# CORS origin for the API. Same-origin via Caddy means "*" is fine.
WEB_ORIGIN=*

# --- Aardvark: ArangoDB admin UI at aardvark.leksis.eu (optional) ---
# Leave ALL of these unset to keep Aardvark unreachable — the docker-compose
# defaults fail closed. To expose it, set all four (and add a DNS A/AAAA record
# for aardvark.leksis.eu pointing at this server):
#
# 1. Hostname — presence of a real domain makes Caddy provision HTTPS.
# AARDVARK_ADDRESS=aardvark.leksis.eu
#
# 2. Gate 1 — allowed source IPs/CIDRs, space-separated. Everyone else gets 403.
#    Default is localhost-only (nobody). Example: one fixed office/home IP.
# AARDVARK_ALLOW_IPS=203.0.113.7/32
#
# 3. Gate 2 — a Caddy login, SEPARATE from ARANGO_ROOT_PASSWORD. Generate with:
#      docker run --rm caddy:2-alpine caddy hash-password --plaintext 'your-pw'
#    Then DOUBLE every "$" to "$$" below (compose reads a lone "$" as a var).
# AARDVARK_USER=admin
# AARDVARK_PASSWORD_HASH=$$2y$$12$$replace.this.with.your.doubled.dollar.hash
