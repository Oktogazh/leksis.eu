# On-demand TLS guard for the PDS wildcard block below: before minting a cert
# for any *.leksis.eu name, Caddy asks the internal gateway (port 9999) whether
# the domain is one we serve. The gateway short-circuits our known static
# hostnames to 200 and forwards everything else to the PDS's own /tls-check
# (which only approves its hostname and registered bot handles). Fail-closed —
# random subdomains get no cert. Harmless when the PDS blocks are inactive.
{
	on_demand_tls {
		ask http://localhost:9999/tls-check
	}
}

# Internal on-demand-TLS gateway. Unpublished (:9999 is never mapped to the
# host), reached only by Caddy's own `ask` above. The PDS's /tls-check 404s for
# aardvark.leksis.eu / leksis.eu (it only knows its own hostname and bot
# handles), which under the wildcard *.leksis.eu policy would fail their certs
# with SSL_ERROR_INTERNAL_ERROR_ALERT. So we approve our known static hostnames
# here first, then defer to the PDS for genuine bot-handle subdomains.
:9999 {
	@known_hosts expression {query.domain} in ["aardvark.leksis.eu", "leksis.eu", "pds.leksis.eu"]
	respond @known_hosts 200
	reverse_proxy pds:3000
}

# Reverse proxy. SITE_ADDRESS is ":80" (HTTP) by default; set it to "leksis.eu"
# (via the env in docker-compose) once DNS points at this server and Caddy will
# provision HTTPS automatically — no other change needed.
{$SITE_ADDRESS} {
	# API lives under /api/* — handle_path strips the prefix, so the browser's
	# /api/health reaches the Hono app as /health.
	#
	# Same-origin traffic (the official leksis.eu SPA) sends no cross-origin
	# Origin header and needs no CORS — it flows straight through, from ANY
	# client IP. The block below ONLY *adds* permission for cross-origin callers
	# (e.g. a developer's frontend on http://localhost:5173): it echoes their
	# Origin back as an allowed origin, but ONLY when their source IP is in
	# ALLOWED_IPS. Everyone else cross-origin gets no CORS headers, so the
	# browser blocks them. Caddy is the edge, so remote_ip is the real,
	# un-spoofable client address. The API itself emits no CORS headers (see
	# apps/api/src/index.ts), so Caddy is the sole CORS authority here — no risk
	# of a duplicate Access-Control-Allow-Origin.
	handle_path /api/* {
		# A cross-origin request from an allowlisted dev IP.
		@dev_cors {
			header Origin *
			remote_ip {$ALLOWED_IPS}
		}

		# Answer the CORS preflight (OPTIONS) directly for allowlisted dev
		# origins so the browser then lets the real request through.
		@dev_preflight {
			method OPTIONS
			header Origin *
			remote_ip {$ALLOWED_IPS}
		}
		handle @dev_preflight {
			header Access-Control-Allow-Origin "{http.request.header.Origin}"
			header Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
			header Access-Control-Allow-Headers "Content-Type, Authorization"
			header Access-Control-Allow-Credentials "true"
			header Vary "Origin"
			respond 204
		}

		# Non-preflight requests from allowlisted dev IPs: proxy to the API and
		# add the CORS response headers the browser needs.
		handle @dev_cors {
			reverse_proxy api:8080 {
				header_down Access-Control-Allow-Origin "{http.request.header.Origin}"
				header_down Access-Control-Allow-Credentials "true"
				header_down +Vary "Origin"
			}
		}

		# Everyone else (same-origin users on any IP; non-allowlisted cross-
		# origin callers) — proxied untouched, no CORS headers added.
		reverse_proxy api:8080
	}

	# Everything else is the static SPA.
	reverse_proxy web:8080
}

# ArangoDB's Aardvark admin UI. DISABLED by default: AARDVARK_ADDRESS is ":8529",
# an internal listener that is never published to the host, so nothing can reach
# it. Set AARDVARK_ADDRESS to "aardvark.leksis.eu" in .env once a DNS record
# points here and Caddy will provision HTTPS automatically.
#
# This is the full database admin console, so access is gated two ways: an IP
# allowlist here (fail-closed — a missing setting denies rather than exposes)
# plus ArangoDB's own root login on the Aardvark page itself. We deliberately do
# NOT add a Caddy basic_auth layer: Aardvark's frontend sends its own
# "Authorization: bearer …" header on every XHR, which displaces the browser's
# Basic credential and makes Caddy 401 every in-app request. route{} keeps the
# IP check ahead of the proxy.
{$AARDVARK_ADDRESS} {
	route {
		# Source-IP gate. Only these IPs/CIDRs pass; everyone else gets 403.
		# Default ALLOWED_IPS is localhost-only (i.e. nobody), so
		# forgetting to set it fails closed. Caddy is the edge here, so
		# remote_ip is the real, un-spoofable client address.
		@denied not remote_ip {$ALLOWED_IPS}
		respond @denied "Forbidden" 403

		reverse_proxy arangodb:8529
	}
}

# Bot-only AT Proto PDS. DISABLED by default: PDS_ADDRESS / PDS_HANDLES_ADDRESS
# are unpublished internal listeners until set in .env (PDS_ADDRESS=
# pds.leksis.eu, PDS_HANDLES_ADDRESS=*.leksis.eu — the DNS wildcard already
# points here). Two addresses, one behaviour: the service hostname gets a
# normal ACME cert; bot-handle subdomains (e.g. wikbot.leksis.eu) are covered
# by the wildcard matcher with on-demand certs, gated by the tls-check ask in
# the global block above. More specific hosts (leksis.eu, aardvark.leksis.eu)
# still win over the wildcard, so the SPA and Aardvark are unaffected.
#
# Part of the PDS must stay PUBLIC for federation to work — the Bluesky relay
# crawls it and resolves handles, which is how bot records reach Jetstream and
# the AppView, and anyone may read a bot's published records. Everything else
# (account/session creation, all writes, app passwords, …) is IP-gated to
# ALLOWED_IPS. The gate is deny-by-default: a request from outside ALLOWED_IPS
# is 403'd unless its path is on the public allowlist below, so any new write
# or session endpoint is gated automatically without a Caddyfile change.
#
# Public (ungated) surface:
#   /.well-known/*                       handle proofs, DID doc, service metadata
#   com.atproto.sync.*                   repo sync + the subscribeRepos WebSocket
#                                        the relay consumes (getRepo, getBlob, …)
#   com.atproto.identity.*               handle/DID resolution
#   com.atproto.server.describeServer    service discovery
#   com.atproto.repo.getRecord           read a single record
#   com.atproto.repo.listRecords         list a collection's records
#   com.atproto.repo.describeRepo        list a repo's collections
# Everything else on /xrpc/* (incl. createAccount, createSession, all writes)
# reaches the PDS only from ALLOWED_IPS.
{$PDS_ADDRESS}, {$PDS_HANDLES_ADDRESS} {
	tls {
		on_demand
	}
	route {
		# 403 anything that is NOT from an allowed IP AND NOT a public path.
		# Caddy is the edge, so remote_ip is the real, un-spoofable client
		# address. `not path …` matches when the path is none of the listed
		# public prefixes; the whole matcher is that AND (not allowed IP).
		@gated {
			not remote_ip {$ALLOWED_IPS}
			not path /.well-known/* \
 /xrpc/com.atproto.sync.* \
 /xrpc/com.atproto.identity.* \
 /xrpc/com.atproto.server.describeServer \
 /xrpc/com.atproto.repo.getRecord \
 /xrpc/com.atproto.repo.listRecords \
 /xrpc/com.atproto.repo.describeRepo
		}
		respond @gated "Forbidden" 403

		# Proxies XRPC, the /.well-known/atproto-did handle proofs, and the
		# com.atproto.sync.subscribeRepos WebSocket the relay consumes.
		reverse_proxy pds:3000
	}
}
